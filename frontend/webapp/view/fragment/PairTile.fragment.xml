<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f">

    <!-- EURUSD -->
    <f:Card class="sapUiSmallMargin forexPairTile">
        <f:header>
            <f:cards.Header title="EURUSD" subtitle="{= ${market>/ticks/EURUSD/bid} || '—' }" press="onPairSelect">
                <f:cards.Header.customData>
                    <core:CustomData key="pair" value="EURUSD"/>
                </f:cards.Header.customData>
            </f:cards.Header>
        </f:header>
        <f:content>
            <HBox class="sapUiTinyMargin">
                <ObjectStatus text="Spread: {= ${market>/ticks/EURUSD/spread} || '—' }" state="Information"/>
            </HBox>
        </f:content>
    </f:Card>

